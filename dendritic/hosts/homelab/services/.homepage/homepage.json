{
    "layout": {
        "Hardware": {
            "style": "row",
            "columns": "3"
        },
        "Media": {
            "style": "row",
            "columns": "3"
        },
        "Work": {
            "style": "row",
            "columns": "1"
        }
    },
    "services": [
        {
            "Hardware": [
                {
                    "Router": {
                        "icon": "sh-openwrt",
                        "description": "Network management",
                        "href": "http://192.168.1.1"
                    }
                },
                {
                    "Proxmox": {
                        "icon": "sh-proxmox",
                        "description": "VM machines management",
                        "href": "https://192.168.1.4:8006"
                    }
                },
                {
                    "TrueNAS": {
                        "icon": "sh-truenas-core",
                        "description": "Storage server",
                        "href": "https://truenas.local"
                    }
                }
            ]
        },
        {
            "Media": [
                {
                    "Jellyfin": {
                        "icon": "sh-jellyfin",
                        "description": "Movies, series, anime and music server",
                        "href": "https://streaming.kike.wtf",
                        "siteMonitor": "https://streaming.kike.wtf",
                        "widget": {
                            "type": "jellyfin",
                            "url": "https://streaming.kike.wtf",
                            "key": "{{HOMEPAGE_VAR_JELLYFIN_API}}",
                            "fields": [
                                "movies",
                                "series",
                                "episodes"
                            ],
                            "enableBlocks": true,
                            "enableNowPlaying": false
                        }
                    }
                },
                {
                    "Komga": {
                        "icon": "sh-komga",
                        "description": "Comic and manga server",
                        "href": "https://books.kike.wtf",
                        "siteMonitor": "https://books.kike.wtf",
                        "widget": {
                            "type": "komga",
                            "url": "https://books.kike.wtf",
                            "username": "{{HOMEPAGE_VAR_KOMGA_USER}}",
                            "key": "{{HOMEPAGE_VAR_KOMGA_API}}",
                            "fields": [
                                "libraries",
                                "series",
                                "books"
                            ]
                        }
                    }
                },
                {
                    "qBitTorrent": {
                        "icon": "sh-qbittorrent",
                        "description": "Torrent client",
                        "href": "https://magnet.kike.wtf",
                        "siteMonitor": "https://magnet.kike.wtf",
                        "widget": {
                            "type": "qbittorrent",
                            "url": "https://magnet.kike.wtf",
                            "username": "user",
                            "password": "{{HOMEPAGE_VAR_QBITTORRENT_PASS}}",
                            "enableLeechProgress": false,
                            "fields": [
                                "leech",
                                "seed",
                                "download"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "Work": [
                {
                    "Presenton": {
                        "icon": "si-slides",
                        "description": "Presentation tool",
                        "href": "https://slides.kike.wtf",
                        "siteMonitor": "https://slides.kike.wtf"
                    }
                }
            ]
        }
    ]
}